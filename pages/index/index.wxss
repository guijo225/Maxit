/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.mabox{
    font-size: 20px;
    font-family: Arial, Helvetica, sans-serif;
    font-weight: 900;
    color: black;
}
.noir{
    background-color: black;
    text-align: center;
    color: white;
    padding: 20px;
    border-radius: 20px;
    margin-top : 20px;
}
.rattacher{
    font-size: 23px;
    padding: 5px;
    font-weight: 800; 
}
.btn {
    background-color: rgb(235, 95, 2);
    border-radius: 10px;
    color: white;
    width: 100px; 
    padding: 10px 0; 
    margin: 20px auto 0 auto;
  } 
.center{
    margin: 25px;
}
.image-style{
    border-radius: 100% ; 
    width: 50px; 
    height: 50px;
    display: inline-block;
    margin: 20px;
    background-color: rgb(92, 86, 86) ;
    padding: 20px; 
}
.scroll-container {
    white-space: nowrap;
    width: 100%;
    overflow-x: scroll;
}
.credit{
    margin: 15px ;
    padding: 15px;
    background-color: gray;
    border-radius: 20px;
    align-items: center;
    justify-content: center;
}
.icon-image {
    height: 30px; 
    width: 30px;
}
.icon-image-eyes {
    height: 30px; 
    width: 30px;
    margin-left: 60px;
}
.credit-text{
    margin-left: 10px;
    color : white;
    opacity: 30%;
}
.trait{
    background-color: gray;
    height: 0.25px;
}
.services{
    margin-left: 30px; 
    margin-top:10px ; 
    font-size: 22px; 
    font-weight: 700;
}
.image-service{
    border-radius: 80% ; 
    width: 50px; 
    height: 50px;
    background-color :rgb(158, 37, 37);
    padding: 10px; 
}

.service-item{
    width: 25%; 
    align-items: center; 
    flex-direction: column; 
    display: flex;
    
}
.container-service{
    display: flex; justify-content: space-around; align-items: center; margin-top: 10px; flex-wrap: wrap;
}